# Application
APP_NAME=FishERP
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://fisherp:fisherp@localhost:5432/fisherp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
