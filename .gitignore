# ============================================================
# FishERP - Root .gitignore
# ============================================================

# ============================================================
# Python
# ============================================================

backend/.venv/
backend/__pycache__/
backend/**/*.py[cod]
backend/.pytest_cache/
backend/.ruff_cache/
backend/.mypy_cache/
backend/.coverage
backend/htmlcov/
backend/.python-version

# ============================================================
# Environment Variables
# ============================================================

backend/.env
backend/.env.*
!backend/.env.example

frontend/.env.local
frontend/.env.*
!frontend/.env.example

# ============================================================
# Logs
# ============================================================

backend/logs/*
!backend/logs/.gitkeep

*.log

# ============================================================
# Alembic
# ============================================================

# Uncomment only if you NEVER want autogenerated revisions
# backend/migrations/versions/*.py

# ============================================================
# Node.js / Next.js
# ============================================================

frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/coverage/

# Package Managers
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# ============================================================
# VS Code
# ============================================================

.vscode/*
!.vscode/extensions.json

# ============================================================
# JetBrains
# ============================================================

.idea/

# ============================================================
# Operating System
# ============================================================

.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# Git
# ============================================================

*.orig
*.rej

# ============================================================
# Docker
# ============================================================

docker-data/
postgres-data/
redis-data/

# ============================================================
# Temporary Files
# ============================================================

tmp/
temp/
*.tmp
*.swp
*.swo

# ============================================================
# Test Reports
# ============================================================

coverage/
pytest-report.xml

# ============================================================
# Build
# ============================================================

dist/
build/

# ============================================================
# Cache
# ============================================================

.cache/
.pyre/

# ============================================================
# Security
# ============================================================

*.pem
*.key
*.crt
*.p12

# ============================================================
# Database Dumps
# ============================================================

*.sql
*.sqlite
*.sqlite3
*.db

# ============================================================
# Misc
# ============================================================

.envrc